generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  STARTER
  PRO
}

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ScanSource {
  MANUAL
  SCHEDULED
  CI
  WORKER_RETRY
}

enum ViolationStatus {
  OPEN
  IN_PROGRESS
  IGNORED
  FIXED
  VERIFIED
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum WorkspaceInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  emailVerified          DateTime?
  name                   String?
  image                  String?
  passwordHash           String?
  plan                   Plan      @default(FREE)
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  emailWeeklyDigest      Boolean   @default(true)
  emailScanAlerts        Boolean   @default(true)

  accounts Account[]
  sites    Site[]
  projects Project[]
  scans    Scan[]
  violationEvents ViolationEvent[]
  violationComments ViolationComment[]
  assignedViolations Violation[] @relation("ViolationAssignee")
  workspaceMemberships WorkspaceMember[]
  sentWorkspaceInvites WorkspaceInvite[] @relation("WorkspaceInviteInviter")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members WorkspaceMember[]
  invites WorkspaceInvite[]
  projects Project[]
  sites Site[]
  scans Scan[]

  @@index([createdAt])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
}

model WorkspaceInvite {
  id          String                @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole         @default(MEMBER)
  token       String                @unique
  status      WorkspaceInviteStatus @default(PENDING)
  invitedById String?
  acceptedAt  DateTime?
  createdAt   DateTime              @default(now())
  expiresAt   DateTime

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User?     @relation("WorkspaceInviteInviter", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Site {
  id               String    @id @default(cuid())
  userId           String
  workspaceId      String?
  url              String
  ciIngestToken    String    @unique @default(cuid())
  slackWebhookUrl  String?   @db.Text
  createdAt        DateTime  @default(now())
  lastAlertSentAt  DateTime?
  lastAlertScanId  String?
  lastDigestSentAt DateTime?
  projectId        String?
  pageId           String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  project  Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  page     Page?     @relation(fields: [pageId], references: [id], onDelete: SetNull)
  scans    Scan[]
  ciChecks CiCheck[]

  @@unique([userId, url])
  @@index([userId])
  @@index([workspaceId])
  @@index([projectId])
  @@index([pageId])
}

model Project {
  id               String   @id @default(cuid())
  userId           String
  workspaceId      String?
  name             String?
  origin           String
  ciIngestToken    String?  @unique
  slackWebhookUrl  String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  pages Page[]
  sites Site[]
  scans Scan[]
  ciChecks CiCheck[]

  @@unique([userId, origin])
  @@index([userId])
  @@index([workspaceId])
}

model Page {
  id        String   @id @default(cuid())
  projectId String
  url       String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sites   Site[]
  scans   Scan[]

  @@unique([projectId, url])
  @@index([projectId])
  @@index([url])
}

model CiCheck {
  id            String   @id @default(cuid())
  siteId        String?
  projectId     String?
  source        String
  status        String
  score         Int?
  criticalCount Int      @default(0)
  seriousCount  Int      @default(0)
  moderateCount Int      @default(0)
  minorCount    Int      @default(0)
  branch        String?
  commitSha     String?
  environment   String?
  runUrl        String?  @db.Text
  reportUrl     String?  @db.Text
  createdAt     DateTime @default(now())

  site    Site?    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([siteId, createdAt])
  @@index([projectId, createdAt])
}

model Scan {
  id              String      @id @default(cuid())
  url             String
  score           Int
  status          ScanStatus  @default(COMPLETED)
  source          ScanSource  @default(MANUAL)
  error           String?
  lastRunError    String?     @db.Text
  startedAt       DateTime?
  completedAt     DateTime?
  attemptCount    Int         @default(0)
  aiReservedMonth String?
  shareToken      String?     @unique
  createdAt       DateTime    @default(now())
  userId          String?
  workspaceId     String?
  siteId          String?
  projectId       String?
  pageId          String?
  violations      Violation[]

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  site    Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  page    Page?    @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@index([url])
  @@index([userId])
  @@index([workspaceId])
  @@index([siteId])
  @@index([projectId])
  @@index([pageId])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([userId, aiReservedMonth])
}

model RateLimitBucket {
  key         String   @id
  windowStart DateTime
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@index([windowStart])
}

model Violation {
  id              String @id @default(cuid())
  scanId          String
  axeId           String
  impact          String
  description     String
  help            String
  helpUrl         String
  element         String  @db.Text
  selector        String  @db.Text
  failureSummary  String? @db.Text
  legalRationale  String? @db.Text
  plainEnglishFix String? @db.Text
  codeExample     String? @db.Text
  aiDetails        Json?
  status          ViolationStatus @default(OPEN)
  statusUpdatedAt DateTime?
  assigneeName    String?
  assigneeEmail   String?
  assigneeUserId  String?
  assignedAt      DateTime?

  scan      Scan                @relation(fields: [scanId], references: [id], onDelete: Cascade)
  assignee User?               @relation("ViolationAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  instances ViolationInstance[]
  events    ViolationEvent[]
  comments  ViolationComment[]

  @@index([scanId])
  @@index([impact])
  @@index([status])
  @@index([assigneeEmail])
  @@index([assigneeUserId])
}

model ViolationInstance {
  id             String  @id @default(cuid())
  violationId    String
  ordinal        Int
  element        String  @db.Text
  selector       String  @db.Text
  failureSummary String? @db.Text

  violation Violation @relation(fields: [violationId], references: [id], onDelete: Cascade)

  @@index([violationId])
  @@unique([violationId, ordinal])
}

model ViolationEvent {
  id             String          @id @default(cuid())
  violationId    String
  userId         String?
  fromStatus     ViolationStatus?
  toStatus       ViolationStatus
  note           String?         @db.Text
  createdAt      DateTime        @default(now())

  violation Violation @relation(fields: [violationId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([violationId, createdAt])
  @@index([userId, createdAt])
}

model ViolationComment {
  id          String   @id @default(cuid())
  violationId String
  userId      String?
  body        String   @db.Text
  createdAt   DateTime @default(now())

  violation Violation @relation(fields: [violationId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([violationId, createdAt])
  @@index([userId, createdAt])
}
