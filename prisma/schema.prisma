generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  STARTER
  PRO
}

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ScanSource {
  MANUAL
  SCHEDULED
  CI
  WORKER_RETRY
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  emailVerified          DateTime?
  name                   String?
  image                  String?
  passwordHash           String?
  plan                   Plan      @default(FREE)
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  emailWeeklyDigest      Boolean   @default(true)
  emailScanAlerts        Boolean   @default(true)

  accounts Account[]
  sites    Site[]
  projects Project[]
  scans    Scan[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Site {
  id               String    @id @default(cuid())
  userId           String
  url              String
  ciIngestToken    String    @unique @default(cuid())
  slackWebhookUrl  String?   @db.Text
  createdAt        DateTime  @default(now())
  lastAlertSentAt  DateTime?
  lastAlertScanId  String?
  lastDigestSentAt DateTime?
  projectId        String?
  pageId           String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project  Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  page     Page?     @relation(fields: [pageId], references: [id], onDelete: SetNull)
  scans    Scan[]
  ciChecks CiCheck[]

  @@unique([userId, url])
  @@index([userId])
  @@index([projectId])
  @@index([pageId])
}

model Project {
  id               String   @id @default(cuid())
  userId           String
  name             String?
  origin           String
  ciIngestToken    String?  @unique
  slackWebhookUrl  String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages Page[]
  sites Site[]
  scans Scan[]
  ciChecks CiCheck[]

  @@unique([userId, origin])
  @@index([userId])
}

model Page {
  id        String   @id @default(cuid())
  projectId String
  url       String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sites   Site[]
  scans   Scan[]

  @@unique([projectId, url])
  @@index([projectId])
  @@index([url])
}

model CiCheck {
  id            String   @id @default(cuid())
  siteId        String?
  projectId     String?
  source        String
  status        String
  score         Int?
  criticalCount Int      @default(0)
  seriousCount  Int      @default(0)
  moderateCount Int      @default(0)
  minorCount    Int      @default(0)
  branch        String?
  commitSha     String?
  environment   String?
  runUrl        String?  @db.Text
  reportUrl     String?  @db.Text
  createdAt     DateTime @default(now())

  site    Site?    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([siteId, createdAt])
  @@index([projectId, createdAt])
}

model Scan {
  id              String      @id @default(cuid())
  url             String
  score           Int
  status          ScanStatus  @default(COMPLETED)
  source          ScanSource  @default(MANUAL)
  error           String?
  lastRunError    String?     @db.Text
  startedAt       DateTime?
  completedAt     DateTime?
  attemptCount    Int         @default(0)
  aiReservedMonth String?
  shareToken      String?     @unique
  createdAt       DateTime    @default(now())
  userId          String?
  siteId          String?
  projectId       String?
  pageId          String?
  violations      Violation[]

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  site    Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  page    Page?    @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@index([url])
  @@index([userId])
  @@index([siteId])
  @@index([projectId])
  @@index([pageId])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([userId, aiReservedMonth])
}

model RateLimitBucket {
  key         String   @id
  windowStart DateTime
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@index([windowStart])
}

model Violation {
  id              String @id @default(cuid())
  scanId          String
  axeId           String
  impact          String
  description     String
  help            String
  helpUrl         String
  element         String  @db.Text
  selector        String  @db.Text
  failureSummary  String? @db.Text
  legalRationale  String? @db.Text
  plainEnglishFix String? @db.Text
  codeExample     String? @db.Text

  scan      Scan                @relation(fields: [scanId], references: [id], onDelete: Cascade)
  instances ViolationInstance[]

  @@index([scanId])
  @@index([impact])
}

model ViolationInstance {
  id             String  @id @default(cuid())
  violationId    String
  ordinal        Int
  element        String  @db.Text
  selector       String  @db.Text
  failureSummary String? @db.Text

  violation Violation @relation(fields: [violationId], references: [id], onDelete: Cascade)

  @@index([violationId])
  @@unique([violationId, ordinal])
}
