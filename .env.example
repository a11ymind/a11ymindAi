# --- Chromium (production / Vercel) ---
# @sparticuz/chromium v130+ no longer bundles the binary in the npm package.
# Set this to a publicly accessible URL for the chromium-pack.tar archive.
# Recommended: upload to Cloudflare R2 and use the public URL.
# Fallback (cold-start slower): leave blank to pull from GitHub releases at runtime.
# Download the pack from: https://github.com/Sparticuz/chromium/releases
CHROMIUM_EXECUTABLE_PATH=""

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/accessly?schema=public"

# --- Anthropic ---
ANTHROPIC_API_KEY=""
# Override default Claude model (default: claude-sonnet-4-6)
ANTHROPIC_MODEL="claude-sonnet-4-6"

# --- Resend (optional for transactional email) ---
# Use a Resend API key with sending access if possible.
# For testing, you can start with something like:
#   a11ymind <onboarding@resend.dev>
# For production, switch to an address on a verified domain:
#   a11ymind <noreply@a11ymind.ai>
RESEND_API_KEY=""
RESEND_FROM_EMAIL="a11ymind <noreply@a11ymind.ai>"

# --- NextAuth ---
# Generate a secret: openssl rand -base64 32
# In production set NEXTAUTH_URL to the canonical app URL: https://www.a11ymind.ai
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# --- Scheduled auto-scans / Vercel Cron ---
# Required in production if you enable the cron route below.
# Vercel automatically sends this value as:
#   Authorization: Bearer <CRON_SECRET>
# when invoking configured cron jobs.
CRON_SECRET=""

# --- Internal scan worker ---
# Protects /api/internal/scan-worker. Generate a random value for production:
#   openssl rand -base64 32
SCAN_WORKER_SECRET=""

# --- Google OAuth (optional) ---
# Leave blank to hide the "Continue with Google" button.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- GitHub OAuth (optional) ---
# Leave blank to hide the "Continue with GitHub" button.
# Create an OAuth App at https://github.com/settings/developers
# Homepage URL: https://www.a11ymind.ai
# Authorization callback URL: https://www.a11ymind.ai/api/auth/callback/github
# For local testing, align the configured callback with your active environment.
GITHUB_ID=""
GITHUB_SECRET=""

# --- App ---
# In production set NEXT_PUBLIC_APP_URL to the canonical app URL: https://www.a11ymind.ai
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Anonymous scan rate limiting (optional) ---
# Defaults:
#   ANON_SCAN_RATE_LIMIT_MAX=5
#   ANON_SCAN_RATE_LIMIT_WINDOW_MS=3600000
ANON_SCAN_RATE_LIMIT_MAX="5"
ANON_SCAN_RATE_LIMIT_WINDOW_MS="3600000"

# --- Cloudflare Turnstile (optional bot-protection on signup) ---
# Leave blank to disable. Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
# Use the "invisible" or "managed" widget type.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# --- Stripe ---
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_STARTER_PRICE_ID="price_REPLACE_ME_STARTER_19USD_MONTHLY"
STRIPE_PRO_PRICE_ID="price_REPLACE_ME_PRO_49USD_MONTHLY"

# --- Sentry (optional; app no-ops if blank) ---
# Public DSN is safe to expose; server DSN falls back to NEXT_PUBLIC_SENTRY_DSN.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
# Only needed at build time to upload source maps. Leave blank in CI/dev.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
